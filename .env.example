# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Discord webhook for failure alerts and daily summaries.
# Leave empty to disable notifications.
# How to get one: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# Set to true during testing to run the full pipeline without actually uploading.
DRY_RUN=false

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
